      "isDeleted": false,
      "boundElements": null,
      "updated": 1776013067162,
      "link": null,
      "locked": false,
      "text": "#include <stdio.h>\n\nint main() {\n    int A, B, C, a, b, c, temp;\n    scanf(\"%d %d %d\", &A, &B, &C);\n\n    // Keep original values to print later\n    a = A; b = B; c = C;\n\n    // Sorting logic (Ascending)\n    if (a > b) { temp = a; a = b; b = temp; }\n    if (a > c) { temp = a; a = c; c = temp; }\n    if (b > c) { temp = b; b = c; c = temp; }\n\n    // Print sorted\n    printf(\"%d\\n%d\\n%d\\n\\n\", a, b, c);\n    \n    // Print original\n    printf(\"%d\\n%d\\n%d\\n\", A, B, C);\n\n    return 0;\n}",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "#include <stdio.h>\n\nint main() {\n    int A, B, C, a, b, c, temp;\n    scanf(\"%d %d %d\", &A, &B, &C);\n\n    // Keep original values to print later\n    a = A; b = B; c = C;\n\n    // Sorting logic (Ascending)\n    if (a > b) { temp = a; a = b; b = temp; }\n    if (a > c) { temp = a; a = c; c = temp; }\n    if (b > c) { temp = b; b = c; c = temp; }\n\n    // Print sorted\n    printf(\"%d\\n%d\\n%d\\n\\n\", a, b, c);\n    \n    // Print original\n    printf(\"%d\\n%d\\n%d\\n\", A, B, C);\n\n    return 0;\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
